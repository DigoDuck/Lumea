# PostgreSQL
POSTGRES_USER=lumea_user
POSTGRES_PASSWORD=lumea_pass
POSTGRES_DB=lumea_db
POSTGRES_PORT=5432

# MongoDB
MONGO_INITDB_ROOT_USERNAME=lumea_user
MONGO_INITDB_ROOT_PASSWORD=lumea_pass
MONGO_PORT=27017

# Backend — JWT
SECRET_KEY=mude_para_uma_chave_segura_de_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Gemini
GEMINI_API_KEY=sua_chave_aqui

# URLs locais (usadas pelo backend fora do Docker)
DATABASE_URL=postgresql+asyncpg://lumea_user:lumea_pass@localhost:5432/lumea_db
MONGODB_URL=mongodb://lumea_user:lumea_pass@localhost:27017